{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/index.py": {
      "maxDuration": 60,
      "excludeFiles": "{venv/**,__pycache__/**,.git/**,.codex/**,.agents/**,token.json,credentials.json}"
    }
  },
  "rewrites": [
    {
      "source": "/api/generate",
      "destination": "/api/index.py"
    },
    {
      "source": "/health",
      "destination": "/api/index.py"
    },
    {
      "source": "/(.*)",
      "destination": "/api/index.py"
    }
  ]
}
